# ─── MailTub Environment Variables ───────────────────────────────────────────
# Copy this file to .env and adjust the values.
# All settings can also be passed as plain environment variables.

# ── HTTP Server ──────────────────────────────────────────────────────────────
PORT=8080

# ── SMTP Server ──────────────────────────────────────────────────────────────
# Port the SMTP server listens on.
# Use 25 for production (requires root / CAP_NET_BIND_SERVICE).
# Use 2525 for unprivileged development.
SMTP_PORT=2525

# The domain that this server accepts email for.
# All addresses will be <local>@<MAILTUB_DOMAIN>.
# In production this must match an MX record pointing at this server.
MAILTUB_DOMAIN=mail.example.com

# Maximum accepted message size in MB.
SMTP_MAX_SIZE_MB=25

# ── Storage ──────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/mailtub.db

# ── Mailbox Lifecycle ─────────────────────────────────────────────────────────
# How long a mailbox lives before it expires (Go duration syntax).
MAILBOX_TTL=24h

# ── Cache (Redis / Upstash — optional) ───────────────────────────────────────
# Leave empty to run without Redis (SQLite-only mode).
# Supports Upstash Redis: rediss://:<token>@<host>:<port>
REDIS_URL=

# ── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info

# ── SMTP TLS / STARTTLS ───────────────────────────────────────────────────────
SMTP_STARTTLS=false
TLS_CERT_FILE=
TLS_KEY_FILE=

# ── MIME / Attachment Limits ──────────────────────────────────────────────────
MAX_ATTACHMENT_SIZE_MB=25
MAX_TOTAL_ATTACHMENT_MB=50
MAX_BODY_KB=512

# ── Application ──────────────────────────────────────────────────────────────
APP_VERSION=v1.0.0

# ── Admin Panel ───────────────────────────────────────────────────────────────
# The admin password is stored as a bcrypt hash in your SQLite database.
# On first run, visit /admin in your browser to complete the setup wizard.
#
# ADMIN_PASSWORD (optional): override the DB-managed password with an env var.
# Use this for Docker / Kubernetes / CI deployments where you want to inject
# the password at container start instead of using the browser wizard.
# Generate: openssl rand -hex 32
# Leave empty to use the browser-based first-run setup wizard (recommended).
ADMIN_PASSWORD=

# ── API Key Authentication ────────────────────────────────────────────────────
# Set to protect /api/v1/* with X-API-Key header auth.
# Leave empty to allow open (unauthenticated) API access.
# Generate: openssl rand -hex 32
API_KEY=
